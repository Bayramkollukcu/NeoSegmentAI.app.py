import streamlit as st
import pandas as pd
import numpy as np
from sklearn.cluster import KMeans
from sklearn.preprocessing import StandardScaler
import matplotlib.pyplot as plt

st.set_page_config(page_title="NeoSegment AI MVP", layout="wide")
st.title("🔄 NeoSegment AI - MVP")
st.markdown("Müşterilerinizi segmentlere ayırın ve bir sonraki ihtiyaçlarını tahmin edin.")

# 1. Örnek veri oluştur (150 müşteri)
np.random.seed(42)
n_customers = 150
data = pd.DataFrame({
    'Müşteri_ID': [f'C{i:03d}' for i in range(n_customers)],
    'Yaş': np.random.randint(18, 70, n_customers),
    'Yıllık_Gelir': np.random.randint(20000, 150000, n_customers),
    'Harcama_Skoru': np.random.randint(0, 100, n_customers),
    'Ziyaret_Sıklığı': np.random.randint(1, 20, n_customers) / 2
})

# 2. Segmentasyon (K-Means, 4 segment)
features = ['Yaş', 'Yıllık_Gelir', 'Harcama_Skoru', 'Ziyaret_Sıklığı']
X = data[features]
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

kmeans = KMeans(n_clusters=4, random_state=42, n_init=10)
data['Segment'] = kmeans.fit_predict(X_scaled)

# 3. Segmentlere anlamlı isimler ver (kurallı)
segment_centers = scaler.inverse_transform(kmeans.cluster_centers_)
names = []
for i, center in enumerate(segment_centers):
    gelir = center[1]
    harcama = center[2]
    if gelir > 80000 and harcama > 70:
        names.append("✨ Premium Sadık")
    elif gelir > 60000 and harcama > 50:
        names.append("💎 Trend Takipçisi")
    elif gelir < 40000 or harcama < 40:
        names.append("🏷️ Fırsat Avcısı")
    else:
        names.append("📈 Potansiyel Yükselen")
data['Segment_Adı'] = data['Segment'].map({i: names[i] for i in range(4)})

# 4. Yan panel: segment isimlerini elle değiştirme imkanı
st.sidebar.header("Segment İsimleri")
custom_names = []
for i in range(4):
    default = names[i]
    new_name = st.sidebar.text_input(f"Segment {i}", value=default, key=f"seg{i}")
    custom_names.append(new_name)
data['Segment_Adı'] = data['Segment'].map({i: custom_names[i] for i in range(4)})

# 5. Ana gösterim
col1, col2 = st.columns([1, 2])

with col1:
    st.subheader("Segment Dağılımı")
    seg_counts = data['Segment_Adı'].value_counts().reset_index()
    seg_counts.columns = ['Segment', 'Müşteri Sayısı']
    st.dataframe(seg_counts, use_container_width=True)
    
    selected_seg = st.selectbox("Bir segment seçin", data['Segment_Adı'].unique())
    seg_data = data[data['Segment_Adı'] == selected_seg]
    st.metric("Müşteri Sayısı", len(seg_data))
    
    # Ortalamalar
    avg = seg_data[features].mean().round(1)
    st.write("**Ortalama Özellikler:**")
    st.write(f"- Yaş: {avg['Yaş']}")
    st.write(f"- Yıllık Gelir: ${avg['Yıllık_Gelir']:,.0f}")
    st.write(f"- Harcama Skoru: {avg['Harcama_Skoru']}")
    st.write(f"- Ziyaret Sıklığı (aylık): {avg['Ziyaret_Sıklığı']}")
    
    # Tahmin: Bir sonraki ürün grubu
    st.subheader("🔮 Tahmin: Sıradaki Ürün Grubu")
    if "Premium" in selected_seg:
        urun = "Lüks koleksiyon, sınırlı üretim aksesuarlar"
    elif "Trend" in selected_seg:
        urun = "Yeni sezon ürünleri, kombin önerileri"
    elif "Fırsat" in selected_seg:
        urun = "Outlet, indirimli setler, kuponlar"
    else:
        urun = "Popüler ürünler, tamamlayıcı parçalar"
    st.success(f"📦 {urun}")
    
with col2:
    st.subheader("Segment Görselleştirme")
    fig, ax = plt.subplots(figsize=(8, 5))
    colors = ['red', 'blue', 'green', 'orange'][:len(custom_names)]
    for i, seg_name in enumerate(custom_names):
        subset = data[data['Segment_Adı'] == seg_name]
        ax.scatter(subset['Yaş'], subset['Harcama_Skoru'], label=seg_name, alpha=0.7)
    ax.set_xlabel("Yaş")
    ax.set_ylabel("Harcama Skoru")
    ax.set_title("Segmentler (Yaş vs Harcama)")
    ax.legend()
    st.pyplot(fig)
    
    st.subheader("Segment Ortalamaları")
    st.dataframe(data.groupby('Segment_Adı')[features].mean().round(1))

st.caption("NeoSegment AI MVP - Ralph Lauren 4D modelinden ilham alınmıştır.")
